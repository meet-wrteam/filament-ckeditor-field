{
    "name": "wrteam/filament-ckeditor-field",
    "description": "A basic CKEditor 5 form field configured with non-premium features.",
    "keywords": [
        "wrteam",
        "laravel",
        "filament-ckeditor-field"
    ],
    "homepage": "https://github.com/meet-wrteam/filament-ckeditor-field",
    "support": {
        "issues": "https://github.com/meet-wrteam/filament-ckeditor-field/issues",
        "source": "https://github.com/meet-wrteam/filament-ckeditor-field"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Meet Wrteam",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3",
        "filament/forms": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "nunomaduro/collision": "^8.1",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Wrteam\\FilamentCkeditorField\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wrteam\\FilamentCkeditorField\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php ./vendor/bin/testbench package:discover --ansi"
        ],
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "phpstan": "vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wrteam\\FilamentCkeditorField\\FilamentCkeditorFieldServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
