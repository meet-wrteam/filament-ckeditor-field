{
    "private": true,
    "type": "module",
    "scripts": {
        "dev:styles": "npx tailwindcss -i resources/css/index.css -o resources/dist/filament-ckeditor-field.css --postcss --watch",
        "dev:scripts": "node bin/build.js --dev",
        "build:styles": "npx tailwindcss -i resources/css/index.css -o resources/dist/filament-ckeditor-field.css --postcss --minify",
        "build:scripts": "node bin/build.js",
        "dev": "npm-run-all --parallel dev:*",
        "build": "npm-run-all build:*",
        "filament-build": "postcss resources/css/index.css -o resources/dist/filament-ckeditor-field.css"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.10",
        "@tailwindcss/typography": "^0.5.19",
        "autoprefixer": "^10.4.22",
        "cssnano": "^6.0.1",
        "esbuild": "^0.27.0",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.5.6",
        "postcss-cli": "^10.1.0",
        "postcss-import": "^15.1.0",
        "postcss-nesting": "^12.0.0",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "^0.1.13",
        "tailwindcss": "^3.3.3"
    },
    "dependencies": {
        "ckeditor5": "^43.1.1"
    }
}